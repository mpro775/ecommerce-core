# Kaleem API production environment template.
# Replace every change-me value with a real secret in the deployment platform.

NODE_ENV=production
PORT=3000
HTTP_JSON_BODY_LIMIT=6mb

DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/kaleem_store
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://USER:PASSWORD@rabbitmq:5672
RABBITMQ_EXCHANGE=kaleem.events

NOTIFICATIONS_MAIN_QUEUE=kaleem.notifications
NOTIFICATIONS_DLQ_QUEUE=kaleem.notifications.dlq
NOTIFICATIONS_RETRY_CREATED_QUEUE=kaleem.notifications.retry.created
NOTIFICATIONS_RETRY_STATUS_QUEUE=kaleem.notifications.retry.status
NOTIFICATIONS_RETRY_INVENTORY_QUEUE=kaleem.notifications.retry.inventory
NOTIFICATIONS_MAX_RETRIES=3
NOTIFICATIONS_RETRY_DELAY_MS=5000

INVENTORY_RESERVATION_TTL_MINUTES=30

THEME_PREVIEW_TOKEN_TTL_MINUTES=60
TEMPLATE_PREVIEW_STORE_URL=https://stores.kaleemstores.com/preview
TEMPLATE_PREVIEW_TOKEN_TTL_MINUTES=60

APP_BASE_DOMAIN=kaleemstores.com
STOREFRONT_ROOT_DOMAIN=kaleemstores.com
STOREFRONT_URL_PATTERN=https://{slug}.kaleemstores.com
STOREFRONT_PREVIEW_HOST=stores.kaleemstores.com
RESERVED_SUBDOMAINS=api,admin,platform,www,mail,smtp,cdn,assets,static,stores,store,checkout,auth,login,register,billing,payments,webhooks,status,blog,docs,dev,staging,prod,demo,kaleem,kaleemstores
TRUST_PROXY=true
DOMAIN_VERIFY_TXT_PREFIX=kaleem-verify
DOMAIN_CNAME_TARGET=stores.kaleemstores.com
DOMAIN_SSL_PROVIDER=cloudflare
DOMAIN_SSL_MODE=full_strict
DOMAIN_SSL_SYNC_INTERVAL_MS=300000
DOMAIN_SSL_SYNC_BATCH_SIZE=100

CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
CLOUDFLARE_API_TOKEN=change-me-cloudflare-token
CLOUDFLARE_ZONE_ID=change-me-cloudflare-zone
CLOUDFLARE_SSL_VALIDATION_METHOD=txt
CLOUDFLARE_MIN_TLS_VERSION=1.2
CLOUDFLARE_TLS_CIPHERS=

PLATFORM_ADMIN_SECRET=change-me-strong-platform-secret-32-chars-minimum
TOKEN_HASH_SECRET=change-me-strong-token-hash-secret-32-chars-minimum
JWT_ACCESS_SECRET=change-me-strong-merchant-jwt-secret-32-chars-minimum
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30
JWT_CUSTOMER_ACCESS_SECRET=change-me-strong-customer-jwt-secret-32-chars-minimum
JWT_CUSTOMER_ACCESS_EXPIRES_IN=15m
CUSTOMER_REFRESH_TOKEN_TTL_DAYS=30
CUSTOMER_PASSWORD_RESET_TTL_MINUTES=30
AUTH_OTP_SECRET=change-me-strong-otp-secret-32-chars-minimum
AUTH_OTP_TTL_MINUTES=5
AUTH_OTP_MAX_VERIFY_ATTEMPTS=3
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_OTP_MAX_RESEND_COUNT=5

S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=kaleem-media
S3_ACCESS_KEY=change-me-storage-access-key
S3_SECRET_KEY=change-me-storage-secret-key
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=https://assets.kaleemstores.com
S3_PRESIGNED_PUT_TTL_SECONDS=900
S3_PRESIGNED_GET_TTL_SECONDS=600

ALLOWED_ORIGINS=https://admin.kaleemstores.com,https://platform.kaleemstores.com,https://kaleemstores.com
CSRF_ENABLED=true
API_PUBLIC_BASE_URL=https://api.kaleemstores.com
STOREFRONT_BASE_URL=https://stores.kaleemstores.com
MERCHANT_ADMIN_BASE_URL=https://admin.kaleemstores.com

SENTRY_DSN=
SENTRY_RELEASE=0.1.0
METRICS_PREFIX=kaleem
CORS_CACHE_TTL_MS=300000
CORS_CACHE_REFRESH_INTERVAL_MS=60000

AUTH_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MS=900000
AUTH_WINDOW_MS=900000

EMAIL_DELIVERY_MODE=smtp
EMAIL_FROM=no-reply@kaleemstores.com
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=change-me-smtp-user
SMTP_PASS=change-me-smtp-pass
RESEND_API_BASE_URL=https://api.resend.com
RESEND_API_KEY=

WEBHOOK_SECRET=change-me-strong-webhook-secret-32-chars-minimum
BILLING_WEBHOOK_SECRET=change-me-strong-billing-webhook-secret-32-chars-minimum

RESTOCK_CONVERSION_WINDOW_DAYS=7
RESTOCK_NOTIFICATION_COOLDOWN_HOURS=6
ABANDONED_CART_INACTIVITY_MINUTES=60
ABANDONED_CART_CAPTURE_BATCH_SIZE=200
ABANDONED_CART_REMINDER_BATCH_SIZE=100
ABANDONED_CART_REMINDER_COOLDOWN_HOURS=24
ABANDONED_CART_WORKER_INTERVAL_MS=60000
